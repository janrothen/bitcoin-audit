# File: /etc/cron.d/bitcoinaudit
# Purpose: Run the Bitcoin Audit bot once a day to post to @BitcoinAudit on X
# Owner: root:root, Permissions: 644 (readable by root & cron daemon)

SHELL=/bin/sh
PATH=/usr/sbin:/usr/bin:/sbin:/bin
HOME=/home/pi/raspberry/bitcoin-audit
LOG=/var/log/bitcoinaudit-cron.log
TZ=Europe/Zurich

# --- Daily audit post (00:00 Swiss time) ----------------------------------
0 0 * * *  pi  cd $HOME && .venv/bin/python -m audit >> $LOG 2>&1
